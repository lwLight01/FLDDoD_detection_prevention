# Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Database ---
DATABASE_URL=postgresql://ddos_user:change_this_password@db:5432/ddos_db
POSTGRES_USER=ddos_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=ddos_db

# --- Authentication (JWT) ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change_this_to_a_random_hex_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Service URLs (Internal Docker Network) ---
RYU_REST_API_URL=http://ryu_controller:8080
FLOWER_SERVER_URL=fl_server:8080
MITIGATION_ENGINE_URL=http://mitigation_engine:8000

# --- Mitigation Engine ---
ALERT_PROBABILITY_THRESHOLD=0.85
RISK_SCORE_WEIGHT_PROB=0.6
RISK_SCORE_WEIGHT_FREQ=0.3
RISK_SCORE_WEIGHT_DECAY=0.1

# --- Federated Learning ---
FL_NUM_ROUNDS=100
FL_MIN_FIT_CLIENTS=10
FL_MIN_AVAILABLE_CLIENTS=15
FL_FRACTION_FIT=0.5
FL_TRUST_PENALTY_THRESHOLD=0.7

# --- Differential Privacy ---
DP_MAX_GRAD_NORM=1.0
DP_NOISE_MULTIPLIER=1.1
DP_TARGET_EPSILON=5.0
DP_TARGET_DELTA=1e-5

# --- Logging ---
LOG_LEVEL=INFO
