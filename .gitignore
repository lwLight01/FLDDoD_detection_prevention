# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables
.env
*.env.local
*.env.production

# Data (large files never committed — keep directory structure via .gitkeep)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/splits/*
!data/splits/.gitkeep
*.pcap
*.csv
*.parquet

# Model checkpoints
checkpoints/
*.pt
*.pth
*.ckpt

# Certificates (secrets)
certs/
*.pem
*.key
*.crt

# Jupyter
.ipynb_checkpoints/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Node / Dashboard
src/dashboard/node_modules/
src/dashboard/dist/
src/dashboard/.next/

# Docker
docker-compose.override.yml

# Testing / Coverage
.pytest_cache/
htmlcov/
.coverage
*.coverage
coverage.xml

# Build
build/
dist/
*.egg-info/

# Alembic
alembic/versions/__pycache__/

# Logs
*.log
logs/
